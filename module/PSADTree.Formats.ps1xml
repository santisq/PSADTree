<?xml version="1.0" encoding="utf-8"?>
<Configuration>
  <ViewDefinitions>
    <View>
      <Name>treeviewad</Name>
      <ViewSelectedBy>
        <TypeName>PSADTree.TreeObjectBase</TypeName>
      </ViewSelectedBy>
      <GroupBy>
        <ScriptBlock>[PSADTree.Internal._FormattingInternals]::GetSource($_)</ScriptBlock>
        <Label>Source</Label>
      </GroupBy>
      <TableControl>
        <TableHeaders>
          <TableColumnHeader>
            <Label>Domain</Label>
            <Alignment>Left</Alignment>
          </TableColumnHeader>
          <TableColumnHeader>
            <Label>ObjectClass</Label>
            <Alignment>Right</Alignment>
          </TableColumnHeader>
          <TableColumnHeader>
            <Label>Hierarchy</Label>
            <Alignment>Left</Alignment>
          </TableColumnHeader>
        </TableHeaders>
        <TableRowEntries>
          <TableRowEntry>
            <TableColumnItems>
              <TableColumnItem>
                <ScriptBlock>[PSADTree.Internal._FormattingInternals]::GetDomain($_)</ScriptBlock>
              </TableColumnItem>
              <TableColumnItem>
                <PropertyName>ObjectClass</PropertyName>
              </TableColumnItem>
              <TableColumnItem>
                <PropertyName>Hierarchy</PropertyName>
              </TableColumnItem>
            </TableColumnItems>
          </TableRowEntry>
        </TableRowEntries>
      </TableControl>
    </View>
    <View>
      <Name>PSADTree.Style.LeafStyle</Name>
      <ViewSelectedBy>
        <TypeName>PSADTree.Style.LeafStyle</TypeName>
      </ViewSelectedBy>
      <ListControl>
        <ListEntries>
          <ListEntry>
            <ListItems>
              <ListItem>
                <Label>Circular</Label>
                <ScriptBlock>
                  [PSADTree.Style.TreeStyle]::EscapeSequence($_.Circular)
                </ScriptBlock>
              </ListItem>
              <ListItem>
                <Label>Processed</Label>
                <ScriptBlock>
                  [PSADTree.Style.TreeStyle]::EscapeSequence($_.Processed)
                </ScriptBlock>
              </ListItem>
            </ListItems>
          </ListEntry>
        </ListEntries>
      </ListControl>
    </View>
    <View>
      <Name>PSADTree.Style.Palette</Name>
      <ViewSelectedBy>
        <TypeName>PSADTree.Style.Palette</TypeName>
      </ViewSelectedBy>
      <ListControl>
        <ListEntries>
          <ListEntry>
            <ListItems>
              <ListItem>
                <Label>Foreground</Label>
                <PropertyName>Foreground</PropertyName>
              </ListItem>
              <ListItem>
                <Label>Background</Label>
                <PropertyName>Background</PropertyName>
              </ListItem>
            </ListItems>
          </ListEntry>
        </ListEntries>
      </ListControl>
    </View>
    <View>
      <Name>PSADTree.Style.Palette.Palettes</Name>
      <ViewSelectedBy>
        <TypeName>PSADTree.Style.Palette+ForegroundPalette</TypeName>
        <TypeName>PSADTree.Style.Palette+BackgroundPalette</TypeName>
      </ViewSelectedBy>
      <ListControl>
        <ListEntries>
          <ListEntry>
            <ListItems>
              <ListItem>
                <Label>Black</Label>
                <ScriptBlock>
                  [PSADTree.Style.TreeStyle]::EscapeSequence($_.Black)
                </ScriptBlock>
              </ListItem>
              <ListItem>
                <Label>BrightBlack</Label>
                <ScriptBlock>
                  [PSADTree.Style.TreeStyle]::EscapeSequence($_.BrightBlack)
                </ScriptBlock>
              </ListItem>
              <ListItem>
                <Label>White</Label>
                <ScriptBlock>
                  [PSADTree.Style.TreeStyle]::EscapeSequence($_.White)
                </ScriptBlock>
              </ListItem>
              <ListItem>
                <Label>BrightWhite</Label>
                <ScriptBlock>
                  [PSADTree.Style.TreeStyle]::EscapeSequence($_.BrightWhite)
                </ScriptBlock>
              </ListItem>
              <ListItem>
                <Label>Red</Label>
                <ScriptBlock>
                  [PSADTree.Style.TreeStyle]::EscapeSequence($_.Red)
                </ScriptBlock>
              </ListItem>
              <ListItem>
                <Label>BrightRed</Label>
                <ScriptBlock>
                  [PSADTree.Style.TreeStyle]::EscapeSequence($_.BrightRed)
                </ScriptBlock>
              </ListItem>
              <ListItem>
                <Label>Magenta</Label>
                <ScriptBlock>
                  [PSADTree.Style.TreeStyle]::EscapeSequence($_.Magenta)
                </ScriptBlock>
              </ListItem>
              <ListItem>
                <Label>BrightMagenta</Label>
                <ScriptBlock>
                  [PSADTree.Style.TreeStyle]::EscapeSequence($_.BrightMagenta)
                </ScriptBlock>
              </ListItem>
              <ListItem>
                <Label>Blue</Label>
                <ScriptBlock>
                  [PSADTree.Style.TreeStyle]::EscapeSequence($_.Blue)
                </ScriptBlock>
              </ListItem>
              <ListItem>
                <Label>BrightBlue</Label>
                <ScriptBlock>
                  [PSADTree.Style.TreeStyle]::EscapeSequence($_.BrightBlue)
                </ScriptBlock>
              </ListItem>
              <ListItem>
                <Label>Cyan</Label>
                <ScriptBlock>
                  [PSADTree.Style.TreeStyle]::EscapeSequence($_.Cyan)
                </ScriptBlock>
              </ListItem>
              <ListItem>
                <Label>BrightCyan</Label>
                <ScriptBlock>
                  [PSADTree.Style.TreeStyle]::EscapeSequence($_.BrightCyan)
                </ScriptBlock>
              </ListItem>
              <ListItem>
                <Label>Green</Label>
                <ScriptBlock>
                  [PSADTree.Style.TreeStyle]::EscapeSequence($_.Green)
                </ScriptBlock>
              </ListItem>
              <ListItem>
                <Label>BrightGreen</Label>
                <ScriptBlock>
                  [PSADTree.Style.TreeStyle]::EscapeSequence($_.BrightGreen)
                </ScriptBlock>
              </ListItem>
              <ListItem>
                <Label>Yellow</Label>
                <ScriptBlock>
                  [PSADTree.Style.TreeStyle]::EscapeSequence($_.Yellow)
                </ScriptBlock>
              </ListItem>
              <ListItem>
                <Label>BrightYellow</Label>
                <ScriptBlock>
                  [PSADTree.Style.TreeStyle]::EscapeSequence($_.BrightYellow)
                </ScriptBlock>
              </ListItem>
            </ListItems>
          </ListEntry>
        </ListEntries>
      </ListControl>
    </View>
    <View>
      <Name>PSADTree.Style.TreeStyle</Name>
      <ViewSelectedBy>
        <TypeName>PSADTree.Style.TreeStyle</TypeName>
      </ViewSelectedBy>
      <ListControl>
        <ListEntries>
          <ListEntry>
            <ListItems>
              <ListItem>
                <Label>OutputRendering</Label>
                <PropertyName>OutputRendering</PropertyName>
              </ListItem>
              <ListItem>
                <Label>RenderingStyle</Label>
                <PropertyName>RenderingStyle</PropertyName>
              </ListItem>
              <ListItem>
                <Label>Reset</Label>
                <ScriptBlock>
                  [PSADTree.Style.TreeStyle]::EscapeSequence($_.Reset)
                </ScriptBlock>
              </ListItem>
              <ListItem>
                <Label>Computer</Label>
                <PropertyName>Computer</PropertyName>
              </ListItem>
              <ListItem>
                <Label>Group</Label>
                <PropertyName>Group</PropertyName>
              </ListItem>
              <ListItem>
                <Label>User</Label>
                <PropertyName>User</PropertyName>
              </ListItem>
              <ListItem>
                <Label>Palette</Label>
                <PropertyName>Palette</PropertyName>
              </ListItem>
            </ListItems>
          </ListEntry>
        </ListEntries>
      </ListControl>
    </View>
  </ViewDefinitions>
</Configuration>
